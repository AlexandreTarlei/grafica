# API (dev local: http://localhost:8000/api/v1 | Docker/nginx: /api/v1)
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Gráfica Online
VITE_COMPANY_ID=1
VITE_DEFAULT_TENANT_ID=1
VITE_COMMERCIAL_VERTICAL=signage
VITE_BUSINESS_SEGMENT=services
VITE_WHATSAPP_PHONE=351912345678
VITE_VISUAL_MAX_UPLOAD_MB=10

# Pagamento: stub (default) | asaas (requer endpoints /billing no backend)
VITE_BILLING_PROVIDER=stub

# Produção / demo real: desligar mocks (omissão = mock ativo em dev)
